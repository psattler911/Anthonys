<script>
  // The Anthony's logo is embedded as the start-screen hero.
  // To swap the game's neon title, edit GAME_NAME below.
  const PIZZERIA_NAME = "ANTHONY'S";    // (logo image is used for branding)
  const GAME_NAME     = "TOPPING DROP"; // <- change the game title if you want
</script>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bungee&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
  :root{
    --night-1:#1c0d18;
    --night-2:#2b1016;
    --crust:#3a1a1e;
    --neon-red:#ff3b53;
    --neon-red-soft:#ff6b7d;
    --cheese:#ffc638;
    --cheese-soft:#ffe08a;
    --basil:#2fe39b;
    --cream:#fff4e6;
    --ink:#13070f;
  }

  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}

  html,body{height:100%;}
  body{
    font-family:'Outfit',system-ui,sans-serif;
    background:
      radial-gradient(120% 80% at 50% -10%, #4a1622 0%, transparent 55%),
      radial-gradient(100% 70% at 50% 110%, #3a0f1c 0%, transparent 60%),
      linear-gradient(180deg,var(--night-1),var(--night-2));
    color:var(--cream);
    overflow:hidden;
    display:flex;
    align-items:center;
    justify-content:center;
    min-height:100dvh;
    user-select:none;
  }

  /* faint checkered tablecloth texture, kept very subtle */
  body::before{
    content:"";
    position:fixed; inset:0;
    background-image:
      linear-gradient(45deg, rgba(255,255,255,.014) 25%, transparent 25%, transparent 75%, rgba(255,255,255,.014) 75%),
      linear-gradient(45deg, rgba(255,255,255,.014) 25%, transparent 25%, transparent 75%, rgba(255,255,255,.014) 75%);
    background-size:54px 54px;
    background-position:0 0, 27px 27px;
    pointer-events:none;
  }

  #stage{
    position:relative;
    width:min(460px, 100vw);
    height:min(820px, 100dvh);
    overflow:hidden;
  }

  canvas{
    position:absolute; inset:0;
    width:100%; height:100%;
    display:block;
    touch-action:none;
  }

  /* ---------- shared screen styling ---------- */
  .screen{
    position:absolute; inset:0;
    display:flex; flex-direction:column;
    align-items:center; justify-content:flex-start;
    text-align:center;
    padding:18px 22px;
    z-index:5;
    overflow-y:auto;
    transition:opacity .25s ease;
  }
  /* center the block when there's room, but collapse + scroll from top when it overflows
     (prevents the top of the logo getting clipped on short screens) */
  .screen::before{ content:""; margin-top:auto; flex:0 0 auto; }
  .screen::after{ content:""; margin-bottom:auto; flex:0 0 auto; }
  .screen.hidden{opacity:0; pointer-events:none;}

  .pizzeria{
    font-size:.78rem; letter-spacing:.32em; font-weight:700;
    color:var(--cheese-soft); text-transform:uppercase;
    margin-bottom:14px; opacity:.9;
  }

  .brand-logo{
    width:min(248px, 58vw);
    height:auto;
    flex:0 0 auto;
    margin-bottom:4px;
    filter:drop-shadow(0 6px 18px rgba(0,0,0,.55));
  }
  .presents{
    font-size:.66rem; letter-spacing:.36em; font-weight:700;
    color:var(--cheese-soft); text-transform:uppercase;
    margin:2px 0 10px; opacity:.85;
  }
  .brand-logo-sm{ width:120px; height:auto; margin-bottom:10px;
    filter:drop-shadow(0 4px 12px rgba(0,0,0,.5)); }

  /* faint in-game brand watermark */
  #watermark{
    position:absolute; left:50%; top:46%;
    transform:translate(-50%,-50%);
    width:62%; max-width:300px;
    opacity:.05; z-index:0; pointer-events:none;
    transition:opacity .3s ease;
  }
  #watermark.hidden{ opacity:0; }

  .logo{
    font-family:'Bungee',cursive;
    line-height:.92;
    font-size:clamp(2.1rem,11vw,3.2rem);
    color:var(--neon-red);
    text-shadow:
      0 0 6px var(--neon-red-soft),
      0 0 22px rgba(255,59,83,.7),
      0 0 48px rgba(255,59,83,.45);
    animation:flicker 6s infinite;
  }
  .logo .drop{ display:block; color:var(--cheese);
    text-shadow:0 0 6px var(--cheese-soft),0 0 22px rgba(255,198,56,.7),0 0 46px rgba(255,198,56,.4);}

  @keyframes flicker{
    0%,18%,22%,25%,53%,57%,100%{opacity:1;}
    20%,24%,55%{opacity:.72;}
  }

  .tagline{ margin-top:18px; max-width:300px; color:#f3d9c9; font-weight:500; line-height:1.45; opacity:.92;}

  .btn{
    font-family:'Outfit',sans-serif;
    font-weight:800; font-size:1.05rem; letter-spacing:.02em;
    color:var(--ink);
    background:linear-gradient(180deg,var(--cheese-soft),var(--cheese));
    border:none; border-radius:999px;
    padding:16px 42px;
    margin-top:30px;
    cursor:pointer;
    box-shadow:0 6px 0 #b6831b, 0 10px 26px rgba(255,198,56,.4);
    transition:transform .08s ease, box-shadow .08s ease;
  }
  .btn:active{ transform:translateY(4px); box-shadow:0 2px 0 #b6831b, 0 6px 14px rgba(255,198,56,.35);}
  .btn:focus-visible{ outline:3px solid var(--basil); outline-offset:3px;}
  .btn.secondary{
    background:transparent; color:var(--cream);
    box-shadow:none; border:2px solid rgba(255,244,230,.32);
    padding:12px 28px; font-size:.92rem; margin-top:16px;
  }
  .btn.secondary:active{ transform:translateY(2px);}

  .howto{ margin-top:26px; display:flex; gap:20px; flex-wrap:wrap; justify-content:center; max-width:330px;}
  .howto div{ font-size:.82rem; color:#e9c9bb; line-height:1.4;}
  .howto .ico{ font-size:1.5rem; display:block; margin-bottom:4px;}

  /* ---------- HUD ---------- */
  #hud{
    position:absolute; top:0; left:0; right:0;
    display:flex; align-items:flex-start; justify-content:space-between;
    padding:14px 16px; z-index:4; pointer-events:none;
  }
  #hud .lives{ font-size:1.15rem; letter-spacing:2px; filter:drop-shadow(0 1px 2px rgba(0,0,0,.5)); }
  #hud .scorebox{ text-align:right; }
  #score{ font-family:'Bungee',cursive; font-size:1.9rem; color:var(--cheese);
    text-shadow:0 0 12px rgba(255,198,56,.5); line-height:1;}
  #combo{ font-weight:800; color:var(--neon-red-soft); font-size:.95rem; height:1.1em; margin-top:2px;}
  #sound-btn{
    pointer-events:auto; position:absolute; top:14px; left:50%; transform:translateX(-50%);
    background:rgba(0,0,0,.25); border:1px solid rgba(255,244,230,.18); color:var(--cream);
    width:38px; height:38px; border-radius:50%; cursor:pointer; font-size:1rem;
  }

  /* ---------- leaderboard ---------- */
  .result-score{ font-family:'Bungee',cursive; font-size:3.6rem; color:var(--cheese);
    text-shadow:0 0 22px rgba(255,198,56,.55); line-height:1; margin:4px 0 2px;}
  .result-label{ letter-spacing:.28em; font-size:.72rem; text-transform:uppercase; color:var(--cheese-soft);}
  .namerow{ margin-top:22px; display:flex; gap:8px; align-items:center; justify-content:center; flex-wrap:wrap;}
  #initials{
    font-family:'Bungee',cursive; text-transform:uppercase; text-align:center;
    width:140px; padding:12px; font-size:1.4rem; letter-spacing:.18em;
    background:rgba(0,0,0,.3); border:2px solid var(--cheese); border-radius:12px; color:var(--cream);
  }
  #initials:focus{ outline:none; box-shadow:0 0 0 3px rgba(255,198,56,.35);}

  .lb-wrap{ width:100%; max-width:340px; margin-top:10px; }
  .lb-title{ display:flex; align-items:center; justify-content:center; gap:8px;
    font-weight:800; letter-spacing:.06em; color:var(--cheese-soft); margin-bottom:10px; font-size:.95rem;}
  .lb-week{ font-size:.72rem; color:#d9b3a6; font-weight:500;}
  .lb-list{ list-style:none; width:100%; }
  .lb-list li{
    display:flex; align-items:center; gap:10px;
    padding:9px 14px; border-radius:10px; margin-bottom:5px;
    background:rgba(255,255,255,.04); font-weight:600; font-size:.95rem;
  }
  .lb-list li.me{ background:linear-gradient(90deg, rgba(255,198,56,.22), rgba(255,59,83,.14));
    box-shadow:inset 0 0 0 1px rgba(255,198,56,.5);}
  .lb-list .rank{ width:26px; font-family:'Bungee',cursive; font-size:.85rem; color:var(--cheese); flex:none;}
  .lb-list .nm{ flex:1; text-align:left; letter-spacing:.04em;}
  .lb-list .sc{ font-family:'Bungee',cursive; font-size:.85rem; color:var(--cream);}
  .lb-empty{ color:#d9b3a6; font-size:.88rem; padding:14px;}

  @media (max-height:680px){
    .logo{font-size:clamp(1.8rem,9vw,2.6rem);}
    .brand-logo{width:min(190px, 46vw);}
    .presents{margin:0 0 6px;}
    .tagline{display:none;}
    .howto{margin-top:16px;}
  }
</style>
