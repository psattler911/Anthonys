<body>
<div id="stage">
  <img id="watermark" class="hidden" alt="" src="data:image/png;base64,">
  <canvas id="game"></canvas>

  <!-- HUD (only visible while playing) -->
  <div id="hud" class="hidden">
    <div class="lives" id="lives">🍕🍕🍕</div>
    <div class="scorebox">
      <div id="score">0</div>
      <div id="combo"></div>
    </div>
  </div>
  <button id="sound-btn" class="hidden" aria-label="Toggle sound">🔊</button>

  <!-- START SCREEN -->
  <div id="start" class="screen">
    <img class="brand-logo" src="data:image/png;base64," alt="Anthony's">
    <div class="presents">presents</div>
    <h1 class="logo" id="logo-1"></h1>
    <p class="tagline">Catch the toppings, dodge the burnt ones, and stack combos. Survive longer, score higher, top the board.</p>
    <div class="howto">
      <div><span class="ico">👈👉</span>Slide to move the peel</div>
      <div><span class="ico">🍄🫑🧀</span>Catch the good stuff</div>
      <div><span class="ico">🧨</span>Dodge burnt slices</div>
    </div>
    <button class="btn" id="play-btn">PLAY</button>
    <button class="btn secondary" id="view-lb-btn">This week's leaderboard</button>
  </div>

  <!-- GAME OVER / LEADERBOARD SCREEN -->
  <div id="over" class="screen hidden">
    <img class="brand-logo-sm" src="data:image/png;base64," alt="Anthony's">
    <div class="result-label" id="over-label">Final score</div>
    <div class="result-score" id="final-score">0</div>

    <div class="namerow" id="namerow">
      <input id="initials" maxlength="3" placeholder="AAA" autocomplete="off">
      <button class="btn" id="save-btn" style="margin-top:0;padding:14px 26px;">Save</button>
    </div>

    <div class="lb-wrap">
      <div class="lb-title">🏆 This Week's Top Slices <span class="lb-week" id="lb-week"></span></div>
      <ul class="lb-list" id="lb-list"></ul>
    </div>

    <button class="btn" id="again-btn">Play again</button>
  </div>
</div>

<script>
/* =========================================================
   SETUP
========================================================= */
const cvs = document.getElementById('game');
const ctx = cvs.getContext('2d');
const stage = document.getElementById('stage');

let W = 0, H = 0, DPR = Math.min(window.devicePixelRatio || 1, 2.5);
function resize(){
  const r = stage.getBoundingClientRect();
  W = r.width; H = r.height;
  cvs.width = W * DPR; cvs.height = H * DPR;
  ctx.setTransform(DPR,0,0,DPR,0,0);
}
window.addEventListener('resize', resize);
resize();

// fill in branding
const logoEl = document.getElementById('logo-1');
(function(){
  const parts = GAME_NAME.trim().split(' ');
  if(parts.length>1){
    const last = parts.pop();
    logoEl.innerHTML = parts.join(' ') + '<span class="drop">'+last+'</span>';
  } else { logoEl.textContent = GAME_NAME; }
})();

const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

/* =========================================================
   SOUND  (tiny Web Audio blips, no files needed)
========================================================= */
let audioCtx = null, soundOn = true;
function ensureAudio(){ if(!audioCtx){ try{ audioCtx = new (window.AudioContext||window.webkitAudioContext)(); }catch(e){} } }
function blip(freq, dur=0.08, type='triangle', vol=0.18){
  if(!soundOn || !audioCtx) return;
  const o = audioCtx.createOscillator(), g = audioCtx.createGain();
  o.type=type; o.frequency.value=freq;
  g.gain.setValueAtTime(vol, audioCtx.currentTime);
  g.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime+dur);
  o.connect(g); g.connect(audioCtx.destination);
  o.start(); o.stop(audioCtx.currentTime+dur);
}
function noiseHit(){
  if(!soundOn || !audioCtx) return;
  const b = audioCtx.createBuffer(1, audioCtx.sampleRate*0.18, audioCtx.sampleRate);
  const d = b.getChannelData(0);
  for(let i=0;i<d.length;i++){ d[i]=(Math.random()*2-1)*Math.pow(1-i/d.length,2); }
  const s = audioCtx.createBufferSource(); s.buffer=b;
  const g = audioCtx.createGain(); g.gain.value=0.3;
  s.connect(g); g.connect(audioCtx.destination); s.start();
}
const sndCatch  = ()=>blip(540+Math.random()*40,0.07,'triangle',0.16);
const sndCombo  = (n)=>blip(440+n*70,0.12,'square',0.14);
const sndStar   = ()=>{ blip(660,0.09,'square',0.16); setTimeout(()=>blip(990,0.12,'square',0.16),70); };
const sndBomb   = ()=>{ noiseHit(); blip(120,0.25,'sawtooth',0.22); };
const sndOver   = ()=>{ [440,330,247].forEach((f,i)=>setTimeout(()=>blip(f,0.18,'sawtooth',0.16),i*140)); };

const soundBtn = document.getElementById('sound-btn');
soundBtn.addEventListener('click', ()=>{
  soundOn=!soundOn; soundBtn.textContent = soundOn?'🔊':'🔇';
});

/* =========================================================
   GAME ENTITIES
========================================================= */
const GOOD = [
  {e:'🍄', pts:10}, {e:'🫑', pts:15}, {e:'🧀', pts:5},
  {e:'🫒', pts:10}, {e:'🥓', pts:15}, {e:'🧅', pts:10},
  {e:'🌶️', pts:20}, {e:'🍍', pts:25}   // pineapple: controversial but delicious 😉
];
const PEPPERONI = {e:'🍕', pts:30};       // rare bonus
const STAR = {e:'⭐', pts:50};            // perfect-pizza bonus
const BOMB = {e:'🧨'};                    // burnt slice -> lose a life

let state = 'menu';           // menu | playing | over
let items = [], particles = [], floaters = [];
let paddle = { x:0, w:96, y:0 };
let score = 0, lives = 3, combo = 0, mult = 1, best = 0;
let spawnTimer = 0, spawnEvery = 60, elapsed = 0, shake = 0;
let pointerX = null;

function resetGame(){
  items=[]; particles=[]; floaters=[];
  score=0; lives=3; combo=0; mult=1; elapsed=0;
  spawnTimer=0; spawnEvery=58; shake=0;
  paddle.w = Math.max(78, W*0.22);
  paddle.x = W/2 - paddle.w/2;
  paddle.y = H - 92;
  pointerX = null;
  updateHud();
}

/* difficulty curves with elapsed time (seconds-ish) */
function difficulty(){
  const t = elapsed/60;                       // ~seconds
  const fall = 2.2 + Math.min(t*0.085, 5.2);  // base fall speed
  const interval = Math.max(20, 58 - t*0.85); // frames between spawns
  const bombChance = Math.min(0.10 + t*0.0032, 0.26);
  return {fall, interval, bombChance};
}

function spawnItem(){
  const d = difficulty();
  const r = Math.random();
  let kind, data;
  if(r < d.bombChance){ kind='bomb'; data=BOMB; }
  else if(r > 0.985){ kind='star'; data=STAR; }
  else if(r > 0.95){ kind='pepperoni'; data=PEPPERONI; }
  else { kind='good'; data=GOOD[(Math.random()*GOOD.length)|0]; }

  const size = 34 + Math.random()*8;
  items.push({
    kind, e:data.e, pts:data.pts||0,
    x: 24 + Math.random()*(W-48),
    y: -40,
    vy: d.fall*(0.85+Math.random()*0.4),
    rot:(Math.random()-0.5)*0.6, spin:(Math.random()-0.5)*0.05,
    size
  });
}

function burst(x,y,color,n=10){
  if(reduceMotion){ n=Math.min(n,4); }
  for(let i=0;i<n;i++){
    const a=Math.random()*Math.PI*2, sp=1.5+Math.random()*3.5;
    particles.push({x,y,vx:Math.cos(a)*sp,vy:Math.sin(a)*sp-2,life:1,color,sz:2+Math.random()*3});
  }
}
function floatText(x,y,txt,color){
  floaters.push({x,y,txt,color,life:1});
}

/* =========================================================
   INPUT
========================================================= */
function setPointer(clientX){
  const r = cvs.getBoundingClientRect();
  pointerX = (clientX - r.left);
}
cvs.addEventListener('mousemove', e=>{ if(state==='playing') setPointer(e.clientX); });
cvs.addEventListener('touchstart', e=>{ if(state==='playing'){ setPointer(e.touches[0].clientX);} }, {passive:true});
cvs.addEventListener('touchmove',  e=>{ if(state==='playing'){ setPointer(e.touches[0].clientX); e.preventDefault?.(); } }, {passive:false});

const keys={};
window.addEventListener('keydown', e=>{ keys[e.key]=true; });
window.addEventListener('keyup',   e=>{ keys[e.key]=false; });

/* =========================================================
   UPDATE + RENDER
========================================================= */
function update(){
  if(state!=='playing') return;
  elapsed++;

  // paddle movement
  if(pointerX!=null){
    const target = pointerX - paddle.w/2;
    paddle.x += (target - paddle.x)*0.4;
  }
  if(keys['ArrowLeft']||keys['a']||keys['A']) paddle.x -= 8;
  if(keys['ArrowRight']||keys['d']||keys['D']) paddle.x += 8;
  paddle.x = Math.max(6, Math.min(W-paddle.w-6, paddle.x));

  // spawning
  const d = difficulty();
  spawnTimer++;
  if(spawnTimer >= d.interval){ spawnTimer=0; spawnItem(); }

  // items
  const padTop = paddle.y, padL = paddle.x, padR = paddle.x+paddle.w;
  for(let i=items.length-1;i>=0;i--){
    const it=items[i];
    it.y += it.vy; it.rot += it.spin;

    // catch test
    const within = it.x>padL-6 && it.x<padR+6 && it.y>padTop-14 && it.y<padTop+30;
    if(within){
      items.splice(i,1);
      if(it.kind==='bomb'){
        lives--; combo=0; mult=1; shake=14;
        burst(it.x,padTop,'#ff3b53',16);
        floatText(it.x,padTop-10,'BURNT!','#ff6b7d');
        sndBomb();
        if(lives<=0){ gameOver(); }
      } else {
        combo++;
        // combo multiplier: 1x, then +1 every 4 catches, cap 8x
        mult = Math.min(1 + Math.floor(combo/4), 8);
        const gain = Math.round(it.pts * mult);
        score += gain;
        if(score>best) best=score;
        burst(it.x,padTop, it.kind==='star'?'#ffe08a':'#ffc638', it.kind==='star'?20:9);
        floatText(it.x,padTop-10,'+'+gain, it.kind==='star'?'#ffe08a':'#fff4e6');
        if(it.kind==='star'){ sndStar(); }
        else if(it.kind==='pepperoni'){ sndCombo(4); }
        else if(combo>1 && combo%4===0){ sndCombo(mult); }
        else { sndCatch(); }
      }
      updateHud();
      continue;
    }

    // fell off bottom
    if(it.y > H+40){
      items.splice(i,1);
      if(it.kind!=='bomb'){ // missing good food breaks combo (no life lost)
        if(combo>0){ combo=0; mult=1; updateHud(); }
      }
    }
  }

  // particles
  for(let i=particles.length-1;i>=0;i--){
    const p=particles[i];
    p.x+=p.vx; p.y+=p.vy; p.vy+=0.18; p.life-=0.025;
    if(p.life<=0) particles.splice(i,1);
  }
  // floaters
  for(let i=floaters.length-1;i>=0;i--){
    const f=floaters[i]; f.y-=0.8; f.life-=0.02;
    if(f.life<=0) floaters.splice(i,1);
  }
  if(shake>0) shake*=0.86;
}

function drawPaddle(){
  // wooden pizza peel
  const x=paddle.x, y=paddle.y, w=paddle.w, h=18;
  ctx.save();
  // glow plate
  ctx.shadowColor='rgba(255,198,56,.55)'; ctx.shadowBlur=18;
  ctx.fillStyle='#e9c08a';
  roundRect(x,y,w,h,9); ctx.fill();
  ctx.shadowBlur=0;
  // board grain
  ctx.fillStyle='#caa066';
  roundRect(x,y+h*0.45,w,h*0.55,9); ctx.fill();
  // handle nub on right
  ctx.fillStyle='#b98a52';
  roundRect(x+w-10,y+3,16,h-6,6); ctx.fill();
  ctx.restore();
}

function roundRect(x,y,w,h,r){
  ctx.beginPath();
  ctx.moveTo(x+r,y);
  ctx.arcTo(x+w,y,x+w,y+h,r);
  ctx.arcTo(x+w,y+h,x,y+h,r);
  ctx.arcTo(x,y+h,x,y,r);
  ctx.arcTo(x,y,x+w,y,r);
  ctx.closePath();
}

function render(){
  ctx.clearRect(0,0,W,H);
  ctx.save();
  if(shake>0.5){ ctx.translate((Math.random()-0.5)*shake,(Math.random()-0.5)*shake); }

  if(state==='playing' || state==='over'){
    // items
    ctx.textAlign='center'; ctx.textBaseline='middle';
    for(const it of items){
      ctx.save();
      ctx.translate(it.x,it.y); ctx.rotate(it.rot);
      ctx.font = it.size+'px serif';
      if(it.kind==='star'){ ctx.shadowColor='#ffe08a'; ctx.shadowBlur=16; }
      if(it.kind==='bomb'){ ctx.shadowColor='#ff3b53'; ctx.shadowBlur=12; }
      ctx.fillText(it.e,0,0);
      ctx.restore();
    }
    if(state==='playing') drawPaddle();

    // particles
    for(const p of particles){
      ctx.globalAlpha=Math.max(p.life,0);
      ctx.fillStyle=p.color;
      ctx.beginPath(); ctx.arc(p.x,p.y,p.sz,0,7); ctx.fill();
    }
    ctx.globalAlpha=1;
    // floaters
    ctx.textAlign='center';
    for(const f of floaters){
      ctx.globalAlpha=Math.max(f.life,0);
      ctx.font='800 20px Outfit, sans-serif';
      ctx.fillStyle=f.color;
      ctx.fillText(f.txt,f.x,f.y);
    }
    ctx.globalAlpha=1;
  }
  ctx.restore();
}

function loop(){ update(); render(); requestAnimationFrame(loop); }
loop();

