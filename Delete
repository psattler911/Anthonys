/* =========================================================
   LEADERBOARD  (weekly, auto-resets each ISO week)
   ---------------------------------------------------------
   NOTE: this stores scores in the browser (localStorage), so the
   board is PER DEVICE. Great for a kiosk/tablet at the counter, or
   for personal bests. To make ONE shared board across every
   customer's phone, swap the two functions below for fetch() calls
   to a tiny backend — see the chat for how. The rest of the game
   doesn't change.
========================================================= */
function isoWeekKey(d){
  const dt=new Date(Date.UTC(d.getFullYear(),d.getMonth(),d.getDate()));
  const day=(dt.getUTCDay()+6)%7;
  dt.setUTCDate(dt.getUTCDate()-day+3);
  const firstThu=new Date(Date.UTC(dt.getUTCFullYear(),0,4));
  const week=1+Math.round(((dt-firstThu)/86400000 - 3 + ((firstThu.getUTCDay()+6)%7))/7);
  return dt.getUTCFullYear()+'-W'+String(week).padStart(2,'0');
}
const LB_KEY = ()=> 'toppingdrop_lb_'+isoWeekKey(new Date());

function lbLoad(){
  try{ return JSON.parse(localStorage.getItem(LB_KEY())) || []; }
  catch(e){ return []; }
}
function lbSave(name, sc){
  const list = lbLoad();
  const entry = {name, score:sc, t:Date.now()};
  list.push(entry);
  list.sort((a,b)=>b.score-a.score);
  const trimmed = list.slice(0,25);
  try{ localStorage.setItem(LB_KEY(), JSON.stringify(trimmed)); }catch(e){}
  return entry;
}

function renderLeaderboard(highlight){
  const list=lbLoad();
  const ul=document.getElementById('lb-list');
  document.getElementById('lb-week').textContent = '('+isoWeekKey(new Date())+')';
  ul.innerHTML='';
  if(!list.length){
    ul.innerHTML='<div class="lb-empty">No scores yet this week. Be the first slice on the board! 🍕</div>';
    return;
  }
  const medals=['🥇','🥈','🥉'];
  list.slice(0,10).forEach((row,i)=>{
    const li=document.createElement('li');
    if(highlight && row===highlight) li.className='me';
    li.innerHTML =
      '<span class="rank">'+(medals[i]||('#'+(i+1)))+'</span>'+
      '<span class="nm">'+escapeHtml(row.name)+'</span>'+
      '<span class="sc">'+row.score.toLocaleString()+'</span>';
    ul.appendChild(li);
  });
}
function escapeHtml(s){ return String(s).replace(/[&<>"']/g, c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

document.getElementById('save-btn').addEventListener('click', ()=>{
  const inp=document.getElementById('initials');
  let name=(inp.value||'').trim().toUpperCase().replace(/[^A-Z0-9]/g,'').slice(0,3);
  if(!name) name='AAA';
  const entry=lbSave(name, score);
  document.getElementById('save-btn').disabled=true;
  document.getElementById('namerow').style.display='none';
  renderLeaderboard(entry);
});
document.getElementById('initials').addEventListener('keydown', e=>{
  if(e.key==='Enter') document.getElementById('save-btn').click();
});

/* prevent scroll-bounce on mobile while playing */
document.addEventListener('touchmove', e=>{ if(state==='playing') e.preventDefault(); }, {passive:false});
